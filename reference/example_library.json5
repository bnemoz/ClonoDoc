// ============================================================================
//  example_library.json5  —  starter lab library for clonodoc
//  Pre-populated with Benjamin's French IgG1 heavy-chain vector and the
//  French overhang set. Copy to your config dir (see docs/02) and enrich.
//  Format: json5 (comments + trailing commas allowed).
// ============================================================================
{
  schema_version: 1,

  vectors: [
    {
      id: "french_igg1_heavy",
      display_name: "French IgG1 Heavy Chain",
      chain_class: "heavy",
      isotype: "IgG1",
      topology: "circular",
      length: 5738,
      sequence_sha256: "50933d38c053a662f687d7a7bdfd4b8f6fcebae11c832224deda1d4f8b93debe",

      // Feature spans are 1-based inclusive (GenBank). Auto-parsed from
      // IgG1_heavy_chain_french_vector.gb; confirm/edit in the UI.
      features: {
        signal_peptide:  { start: 1,    end: 57   },
        constant_region: { start: 58,   end: 1047, name: "IGHG1" },
        resistance:      { start: 2774, end: 3634, name: "AmpR"  },
        origin:          { start: 3779, end: 4452, name: "pUC"   },
        promoter:        { start: 4811, end: 5428, name: "CMV"   },
      },
      insertion_site: { oh5_end: 57, oh3_start: 57 },
      constant_anchor_aa: "ASTKGPSV",
      overhang_set: "french_default",
      overhang_locus: "IGH",
      provenance: { added_by: "benjamin", added: "2026-05-22", source_file: "IgG1_heavy_chain_french_vector.gb" },

      // Full ORIGIN sequence (5738 nt, uppercase, no spaces):
      sequence: "",
    },

    // ---- Placeholders: add your kappa and lambda light-chain vectors -----
    // {
    //   id: "french_igk_light", display_name: "French Kappa Light",
    //   chain_class: "kappa", isotype: "kappa", topology: "circular",
    //   features: { signal_peptide:{...}, constant_region:{... name:"IGKC"},
    //               resistance:{... name:"AmpR"} },
    //   insertion_site: { oh5_end: ?, oh3_start: ? },
    //   constant_anchor_aa: "RTVAAPSV",   // kappa C-region start
    //   overhang_set: "french_default", overhang_locus: "IGK",
    //   sequence: "...", sequence_sha256: "...",
    // },
    // {
    //   id: "french_igl_light", ... overhang_locus: "IGL",
    //   constant_anchor_aa: "GQPKAAPSV", // lambda C-region start
    // },
  ],

  overhang_sets: [
    {
      id: "french_default",
      display_name: "French vector overhangs",
      // NOTE: oh_5 IGK == oh_5 IGL (shared light leader).
      //       oh_3 IGK != oh_3 IGL  -> the 3' overhang is the kappa/lambda discriminator.
      oh_5: {
        IGH: "GCTGGGTTTTCCTTGTTGCTATTCTCGAGGGTGTCCAGTGT",
        IGK: "ATCCTTTTTCTAGTAGCAACTGCAACCGGTGTACAC",
        IGL: "ATCCTTTTTCTAGTAGCAACTGCAACCGGTGTACAC",
      },
      oh_3: {
        IGH: "GCTAGCACCAAGGGCCCATCGGTCTTCC",
        IGK: "CGTACGGTGGCTGCACCATCTGTCTTCATC",
        IGL: "GGTCAGCCCAAGGCTGCCCCCTCGGTCACTCTGTTCCCGCCCTCGAGTGAGGAGCTTCAAGCCAACAAGGCC",
      },
      provenance: { added_by: "benjamin", added: "2026-05-22" },
    },
  ],

  naming_profiles: [
    {
      id: "default",
      display_name: "Default (broad synonyms)",
      chain_synonyms: {
        heavy:  ["heavychain","heavy","hchain","hc","vh","igh","h"],
        kappa:  ["kappachain","kappa","igk","vk","k"],
        lambda: ["lambdachain","lambda","igl","vl","l"],
        light:  ["lightchain","light","lchain","lc"],
      },
      id_regex: "^(?<ab_id>.+?)[_\\-\\s]*(?<chain>heavy|light|hc|lc|kappa|lambda|[hkl])$",
      separators: ["_","-"," ",":"],
    },
  ],

  alignment: {
    protein_matrix: "BLOSUM62",
    protein_gap_open: -11, protein_gap_extend: -1,
    nt_match: 2, nt_mismatch: -3, nt_gap_open: -5, nt_gap_extend: -1,
    backbone_identity_min: 0.97,
    overhang_max_mismatch: 1,
  },

  optimization_checks: {
    gc_max_global: 0.56,
    gc_max_window: 0.64, gc_window: 60,
    rare_codon_min_frequency: 0.05, species: "h_sapiens",
    enabled: true,
  },
}
